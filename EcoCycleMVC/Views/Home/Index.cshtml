@{
    ViewData["Title"] = "Inicio";
}

<!-- ===========================
        MENÚ
============================ -->

<nav class="navbar navbar-expand-lg navbar-dark bg-success shadow fixed-top">

    <div class="container">

        <a class="navbar-brand fw-bold fs-3"
           asp-controller="Home"
           asp-action="Index">
            🌎 EcoCycle
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#menu"
                aria-controls="menu"
                aria-expanded="false"
                aria-label="Toggle navigation">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="menu">

            <ul class="navbar-nav ms-auto align-items-lg-center">

                <li class="nav-item">
                    <a class="nav-link"
                       asp-controller="Home"
                       asp-action="Index">
                        <i class="bi bi-house-door-fill"></i>
                        Inicio
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#nosotros">
                        Nosotros
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#materiales">
                        Materiales
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#funciona">
                        ¿Cómo funciona?
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link"
                       asp-controller="Usuarios"
                       asp-action="Login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Iniciar Sesión
                    </a>
                </li>

                <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                    <a class="btn btn-warning fw-bold"
                       asp-controller="Usuarios"
                       asp-action="Registro">
                        <i class="bi bi-person-plus-fill"></i>
                        Registrarse
                    </a>
                </li>

            </ul>

        </div>

    </div>

</nav>

<!-- ===========================
        HERO
============================ -->

<section class="hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <h1 class="display-3 fw-bold">

                    Recicla.
                    <br />
                    Gana.
                    <br />
                    Cuida el planeta.

                </h1>

                <p class="lead mt-4">

                    EcoCycle conecta a las personas con centros de reciclaje para convertir residuos reciclables en puntos y recompensas.

                </p>

                <a href="#funciona"
                   class="btn btn-success btn-lg mt-3">

                    Comenzar

                </a>

            </div>

            <div class="col-lg-6 text-center">

                <img src="~/assets/img/hero-carousel/hero-carousel-1.jpg"
                     class="img-fluid rounded shadow"
                     alt="EcoCycle">

            </div>

        </div>

    </div>

</section>

<!-- ===========================
        NOSOTROS
============================ -->

<section id="nosotros">

    <div class="container">

        <h2 class="text-center mb-5">
            ¿Qué es EcoCycle?
        </h2>

        <div class="row g-4">

            <div class="col-md-4">

                <div class="card shadow p-4 text-center h-100">

                    <h1>🌱</h1>

                    <h4 class="mt-3">
                        Reciclaje
                    </h4>

                    <p>

                        Promovemos el reciclaje responsable para reducir la contaminación y cuidar nuestro entorno.

                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow p-4 text-center h-100">

                    <h1>🏆</h1>

                    <h4 class="mt-3">
                        Recompensas
                    </h4>

                    <p>

                        Acumula puntos cada vez que entregues materiales reciclables y canjéalos por premios.

                    </p>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card shadow p-4 text-center h-100">

                    <h1>🌎</h1>

                    <h4 class="mt-3">
                        Medio Ambiente
                    </h4>

                    <p>

                        Cada kilo reciclado ayuda a disminuir los residuos y protege el planeta.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ===========================
        MATERIALES
============================ -->

<section id="materiales" class="bg-light">

    <div class="container">

        <h2 class="text-center mb-5">

            Materiales aceptados

        </h2>

        <div class="row g-4">

            <div class="col-md-3">

                <div class="card text-center shadow p-4 h-100">

                    <h1>♻️</h1>

                    <h5>Plástico</h5>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card text-center shadow p-4 h-100">

                    <h1>📰</h1>

                    <h5>Papel</h5>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card text-center shadow p-4 h-100">

                    <h1>🍾</h1>

                    <h5>Vidrio</h5>

                </div>

            </div>

            <div class="col-md-3">

                <div class="card text-center shadow p-4 h-100">

                    <h1>🥫</h1>

                    <h5>Metal</h5>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ===========================
        FUNCIONA
============================ -->

<section id="funciona">

    <div class="container">

        <h2 class="text-center mb-5">

            ¿Cómo funciona?

        </h2>

        <div class="row text-center g-4">

            <div class="col-md-3">

                <h1>1️⃣</h1>

                <h5>Regístrate</h5>

                <p>
                    Crea una cuenta en EcoCycle.
                </p>

            </div>

            <div class="col-md-3">

                <h1>2️⃣</h1>

                <h5>Entrega residuos</h5>

                <p>
                    Lleva tus materiales al centro de reciclaje.
                </p>

            </div>

            <div class="col-md-3">

                <h1>3️⃣</h1>

                <h5>Obtén puntos</h5>

                <p>
                    Acumula puntos por cada kilogramo reciclado.
                </p>

            </div>

            <div class="col-md-3">

                <h1>4️⃣</h1>

                <h5>Canjea recompensas</h5>

                <p>
                    Intercambia tus puntos por premios.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- ===========================
        LLAMADO A LA ACCIÓN
============================ -->

<section class="bg-success text-white text-center py-5">

    <div class="container">

        <h2 class="mb-3">

            Juntos podemos hacer la diferencia.

        </h2>

        <p class="lead">

            Miles de kilos reciclados gracias a nuestra comunidad.

        </p>

        <a asp-controller="Usuarios"
           asp-action="Registro"
           class="btn btn-light btn-lg mt-3">

            Únete Ahora

        </a>

    </div>

</section>