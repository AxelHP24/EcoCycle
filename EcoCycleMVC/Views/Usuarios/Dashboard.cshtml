@model EcoCycleMVC.Models.Usuario

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">

    <div class="row">

        <!-- PERFIL -->
        <div class="col-lg-4 mb-4">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body text-center">

                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                         class="rounded-circle mb-3"
                         width="150" />

                    <h3>@Model.Nombre</h3>

                    <p class="text-muted">@Model.Correo</p>

                    <hr />

                    <p>
                        <strong>📱 Teléfono</strong><br />
                        @(string.IsNullOrEmpty(Model.Telefono) ? "No registrado" : Model.Telefono)
                    </p>

                    <p>
                        <strong>🏠 Dirección</strong><br />
                        @(string.IsNullOrEmpty(Model.Direccion) ? "No registrada" : Model.Direccion)
                    </p>

                    <h4 class="text-success mt-3">
                        ⭐ @Model.Puntos Puntos
                    </h4>

                    <a asp-action="EditarPerfil"
                       class="btn btn-success w-100 mt-3">
                        Editar Perfil
                    </a>

                    <a asp-action="Logout"
                       class="btn btn-danger w-100 mt-2">
                        Cerrar Sesión
                    </a>

                </div>

            </div>

        </div>

        <!-- OPCIONES -->
        <div class="col-lg-8">

            <h2 class="mb-4">
                ¡Bienvenido, @Model.Nombre!
            </h2>

            <div class="row">

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>♻</h1>

                            <h4>Publicar Material</h4>

                            <p>
                                Registra materiales reciclables para obtener puntos.
                            </p>

                            <!-- BOTÓN AGREGADO -->
                            <a asp-controller="Publicaciones"
                               asp-action="Crear"
                               class="btn btn-success mt-3">

                                Publicar

                            </a>

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>🏆</h1>

                            <h4>Mis Recompensas</h4>

                            <p>
                                Consulta tus recompensas disponibles.
                            </p>

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>🚚</h1>

                            <h4>Solicitar Recogida</h4>

                            <p>
                                Programa una recolección a domicilio.
                            </p>

                        </div>

                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>📍</h1>

                            <h4>Centros de Reciclaje</h4>

                            <p>
                                Encuentra el centro más cercano.
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>