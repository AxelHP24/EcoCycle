@model EcoCycleMVC.Models.Usuario

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">

        <!--================ PERFIL =================-->

        <div class="col-lg-4 mb-4">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-body text-center">

                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                         width="150"
                         class="rounded-circle shadow mb-3" />

                    <h3 class="fw-bold">@Model.Nombre</h3>

                    <p class="text-muted">@Model.Correo</p>

                    <hr />

                    <p>
                        <strong>📱 Teléfono</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.Telefono)
                            ? "No registrado"
                            : Model.Telefono)
                    </p>

                    <p>
                        <strong>📍 Dirección</strong><br />
                        @(string.IsNullOrWhiteSpace(Model.Direccion)
                            ? "No registrada"
                            : Model.Direccion)
                    </p>

                    <div class="alert alert-success">

                        <h3 class="mb-0">

                            ⭐ @Model.Puntos Puntos

                        </h3>

                    </div>

                    <a asp-controller="Usuarios"
                       asp-action="EditarPerfil"
                       class="btn btn-success w-100 mb-2">

                        ✏ Editar Perfil

                    </a>

                    <a asp-controller="Usuarios"
                       asp-action="Logout"
                       class="btn btn-danger w-100">

                        🚪 Cerrar Sesión

                    </a>

                </div>

            </div>

        </div>

        <!--================ MENÚ =================-->

        <div class="col-lg-8">

            <h2 class="mb-4">

                ¡Bienvenido @Model.Nombre! 👋

            </h2>

            <div class="row">

                <!-- PUBLICAR MATERIAL -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>♻</h1>

                            <h4>Publicar Material</h4>

                            <p>

                                Registra materiales reciclables para obtener puntos.

                            </p>

                            <a asp-controller="Publicaciones"
                               asp-action="Crear"
                               class="btn btn-success">

                                Publicar

                            </a>

                        </div>

                    </div>

                </div>

                <!-- MIS PUBLICACIONES -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>📦</h1>

                            <h4>Mis Publicaciones</h4>

                            <p>

                                Consulta, edita o elimina tus publicaciones.

                            </p>

                            <a asp-controller="Publicaciones"
                               asp-action="MisPublicaciones"
                               class="btn btn-primary">

                                Ver Publicaciones

                            </a>

                        </div>

                    </div>

                </div>

                <!-- RECOGIDAS -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>🚚</h1>

                            <h4>Solicitar Recogida</h4>

                            <p>

                                Agenda una recolección a domicilio.

                            </p>

                            <a asp-controller="Recogidas"
                               asp-action="Crear"
                               class="btn btn-warning">

                                Solicitar

                            </a>

                        </div>

                    </div>

                </div>

                <!-- CENTROS -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>📍</h1>

                            <h4>Centros de Reciclaje</h4>

                            <p>

                                Consulta los centros registrados.

                            </p>

                            <a asp-controller="Centros"
                               asp-action="Index"
                               class="btn btn-info text-white">

                                Ver Centros

                            </a>

                        </div>

                    </div>

                </div>

                <!-- RECOMPENSAS -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>🏆</h1>

                            <h4>Recompensas</h4>

                            <p>

                                Canjea tus puntos por premios.

                            </p>

                            <a asp-controller="Recompensas"
                               asp-action="Index"
                               class="btn btn-success">

                                Ver Recompensas

                            </a>

                        </div>

                    </div>

                </div>

                <!-- HISTORIAL -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>⭐</h1>

                            <h4>Historial de Puntos</h4>

                            <p>

                                Consulta todos los movimientos de puntos de tu cuenta.

                            </p>

                            <a asp-controller="Usuarios"
                               asp-action="HistorialPuntos"
                               class="btn btn-secondary">

                                Ver Historial

                            </a>

                        </div>

                    </div>

                </div>

                <!-- NOTIFICACIONES -->

                <div class="col-md-6 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body text-center">

                            <h1>🔔</h1>

                            <h4>Notificaciones</h4>

                            <p>

                                Consulta los avisos del sistema EcoCycle.

                            </p>

                            <a asp-controller="Notificaciones"
                               asp-action="Index"
                               class="btn btn-dark">

                                Abrir

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>