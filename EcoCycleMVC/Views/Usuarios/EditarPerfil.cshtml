@model EcoCycleMVC.Models.Usuario

@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-success text-white">

                    <h2>Editar Perfil</h2>

                </div>

                <div class="card-body">

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success">

                            @TempData["Mensaje"]

                        </div>
                    }

                    <form asp-action="EditarPerfil" method="post">

                        <input asp-for="UsuarioId" type="hidden"/>

                        <div class="mb-3">

                            <label class="form-label">

                                Nombre

                            </label>

                            <input asp-for="Nombre"
                                   class="form-control"/>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Teléfono

                            </label>

                            <input asp-for="Telefono"
                                   class="form-control"/>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">

                                Dirección

                            </label>

                            <textarea asp-for="Direccion"
                                      class="form-control"
                                      rows="4"></textarea>

                        </div>

                        <button class="btn btn-success">

                            Guardar Cambios

                        </button>

                        <a asp-action="Dashboard"
                           class="btn btn-secondary">

                            Cancelar

                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>