@model List<EcoCycleMVC.Models.Publicacione>

@{
    ViewData["Title"] = "Centros de Reciclaje";
}

<div class="container mt-5">

    <h2 class="text-success mb-4">
        📍 Centros de Reciclaje
    </h2>

    @if (Model.Count == 0)
    {
        <div class="alert alert-warning">
            No existen ubicaciones registradas.
        </div>
    }
    else
    {
        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">

                    <div class="card shadow h-100">

                        <div class="card-body">

                            <div class="text-center">
                                <h3>♻</h3>

                                <h5>Ubicación</h5>

                                <hr />

                                <p class="fw-bold">
                                    @item.Ubicacion
                                </p>

                                <p>
                                    Material:
                                    <strong>@item.MaterialId</strong>
                                </p>

                                <p>
                                    Cantidad:
                                    <strong>@item.CantidadKg Kg</strong>
                                </p>

                                <span class="badge bg-success">
                                    @item.Estado
                                </span>
                            </div>

                            <div class="mt-3">

                                <iframe
                                    width="100%"
                                    height="250"
                                    style="border:0; border-radius:10px;"
                                    loading="lazy"
                                    allowfullscreen
                                    src="https://www.google.com/maps?q=@Uri.EscapeDataString(item.Ubicacion)&output=embed">
                                </iframe>

                            </div>

                            <div class="d-grid mt-3">

                                <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(item.Ubicacion)"
                                   target="_blank"
                                   class="btn btn-primary">

                                    📍 Abrir en Google Maps

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>