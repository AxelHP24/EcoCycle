
@model EcoCycleMVC.Models.NuevaPublicacionViewModel

@{
    ViewData["Title"] = "Publicar Material";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-success text-white text-center p-4">

                    <h2>♻ Publicar Material Reciclable</h2>

                    <p class="mb-0">
                        Comparte materiales reciclables y gana puntos EcoCycle.
                    </p>

                </div>

                <div class="card-body p-4">

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["Mensaje"]
                        </div>
                    }

                    <form asp-action="Crear" method="post">

                        <div class="mb-4">

                            <label asp-for="MaterialId" class="form-label fw-bold">
                                Material
                            </label>

                            <select asp-for="MaterialId"
                                    asp-items="Model.Materiales"
                                    class="form-select">

                                <option value="">Seleccione un material</option>

                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="CantidadKg" class="form-label fw-bold">
                                Cantidad (Kg)
                            </label>

                            <input asp-for="CantidadKg"
                                   class="form-control"
                                   placeholder="Ejemplo: 5" />

                        </div>

                        <div class="mb-4">

                            <label asp-for="Ubicacion" class="form-label fw-bold">
                                Ubicación
                            </label>

                            <input asp-for="Ubicacion"
                                   class="form-control"
                                   placeholder="Ejemplo: Colonia Centro" />

                        </div>

                        <div class="mb-4">

                            <label asp-for="Descripcion" class="form-label fw-bold">
                                Descripción
                            </label>

                            <textarea asp-for="Descripcion"
                                      rows="5"
                                      class="form-control"
                                      placeholder="Describe el material..."></textarea>

                        </div>

                        <div class="text-center">

                            <button class="btn btn-success btn-lg px-5">

                                ♻ Publicar Material

                            </button>

                            <a asp-controller="Usuarios"
                               asp-action="Dashboard"
                               class="btn btn-secondary btn-lg ms-2">

                                Cancelar

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts{

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}