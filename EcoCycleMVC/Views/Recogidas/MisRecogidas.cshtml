@model List<EcoCycleMVC.Models.RecogidasDomicilio>

@{
    ViewData["Title"] = "Mis Recogidas";
}

<div class="container mt-5">

    <h2 class="mb-4">🚚 Mis Recogidas</h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensaje"]
        </div>
    }

    <table class="table table-bordered">

        <thead class="table-success">

            <tr>
                <th>Centro</th>
                <th>Dirección</th>
                <th>Fecha Solicitud</th>
                <th>Fecha Programada</th>
                <th>Estado</th>
                <th></th>
            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Centro.NombreCentro</td>
                    <td>@item.Direccion</td>
                    <td>@item.FechaSolicitud</td>
                    <td>@item.FechaProgramada</td>
                    <td>@item.Estado</td>
                    <td>
                        <a asp-action="Cancelar"
                           asp-route-id="@item.RecogidaId"
                           class="btn btn-danger btn-sm">

                            Cancelar

                        </a>
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>