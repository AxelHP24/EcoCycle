@model List<EcoCycleMVC.Models.RecogidasDomicilio>

@{
    ViewData["Title"] = "Mis Recogidas";
}

<div class="container mt-5">

    <h2 class="mb-4">

        🚚 Mis Solicitudes de Recogida

    </h2>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">

            @TempData["Mensaje"]

        </div>
    }

    <table class="table table-striped table-hover shadow">

        <thead class="table-success">

            <tr>

                <th>Centro</th>

                <th>Dirección</th>

                <th>Fecha Programada</th>

                <th>Estado</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {

                <tr>

                    <td>

                        @item.Centro.NombreCentro

                    </td>

                    <td>

                        @item.Direccion

                    </td>

                    <td>

                        @item.FechaProgramada?.ToString("dd/MM/yyyy HH:mm")

                    </td>

                    <td>

                        @if (item.Estado == "Pendiente")
                        {
                            <span class="badge bg-warning text-dark">

                                Pendiente

                            </span>
                        }
                        else if (item.Estado == "Aceptada")
                        {
                            <span class="badge bg-primary">

                                Aceptada

                            </span>
                        }
                        else if (item.Estado == "En camino")
                        {
                            <span class="badge bg-info">

                                En camino

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">

                                Finalizada

                            </span>
                        }

                    </td>

                </tr>

            }

        </tbody>

    </table>

</div>